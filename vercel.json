{
  "headers": [
    {
      "source": "/shim.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/en", "destination": "/" },
    { "source": "/en/:path*", "destination": "/" },
    { "source": "/((?!api|assets|.*\\..*).*)", "destination": "/" }
  ]
}
